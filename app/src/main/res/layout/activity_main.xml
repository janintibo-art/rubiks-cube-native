<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0d0d12">

    <com.tiboja.cubenova.CubeGLSurfaceView
        android:id="@+id/glView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Barre supérieure : titre + bouton menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:src="@drawable/logo_top"
            android:scaleType="fitStart"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name" />

        <Button
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_neon"
            android:text="☰ Menu"
            android:textColor="#EAEAFF"
            android:textAllCaps="false"
            android:paddingLeft="18dp"
            android:paddingRight="18dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Panneau de menu rétractable (caché par défaut) -->
    <LinearLayout
        android:id="@+id/menuPanel"
        android:layout_width="210dp"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="66dp"
        android:layout_marginEnd="14dp"
        android:orientation="vertical"
        android:background="@drawable/panel_bg"
        android:padding="12dp"
        android:visibility="gone">

        <Button android:id="@+id/miLevel" style="@style/MenuItemButton" android:text="🎚  Niveau" />
        <Button android:id="@+id/miTheme" style="@style/MenuItemButton" android:text="🎨  Thème" />
        <Button android:id="@+id/miView" style="@style/MenuItemButton" android:text="🧭  Vue : Libre" />
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#3D4CCF" android:layout_marginTop="4dp" android:layout_marginBottom="8dp" />
        <Button android:id="@+id/miChallenges" style="@style/MenuItemButton" android:text="🎯  Défis" />
        <Button android:id="@+id/miDaily" style="@style/MenuItemButton" android:text="🗓  Défi du jour" />
        <Button android:id="@+id/miLeaderboard" style="@style/MenuItemButton" android:text="🏆  Classement" />
        <Button android:id="@+id/miAchievements" style="@style/MenuItemButton" android:text="⭐  Succès" />
        <Button android:id="@+id/miStats" style="@style/MenuItemButton" android:text="📊  Statistiques" />
        <Button android:id="@+id/miSettings" style="@style/MenuItemButton" android:text="⚙  Paramètres" />
        <Button android:id="@+id/miGraphics" style="@style/MenuItemButton" android:text="🎛  Graphismes" />
    </LinearLayout>

    <!-- Chrono + coups -->
    <LinearLayout
        android:id="@+id/hud"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="66dp"
        android:orientation="horizontal"
        android:background="#66000000"
        android:padding="8dp">

        <TextView
            android:id="@+id/txtTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0 s"
            android:textColor="#4DD0E1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:minWidth="90dp"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="  •  "
            android:textColor="#88FFFFFF"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/txtMoves"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 coups"
            android:textColor="#FFD54F"
            android:textSize="18sp"
            android:textStyle="bold"
            android:minWidth="90dp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Joystick de rotation (coin bas gauche) -->
    <com.tiboja.cubenova.JoystickView
        android:id="@+id/joystick"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="26dp" />

    <!-- Actions : grille compacte 2x2 + 1, alignée en bas à droite -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:orientation="vertical"
        android:gravity="end"
        android:paddingEnd="18dp"
        android:paddingBottom="30dp">

        <!-- Ligne 1 : Indice, Aperçu -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnHint"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_round"
                android:textColor="#EAEAFF"
                android:text="💡"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:contentDescription="Indice" />

            <Button
                android:id="@+id/btnPeek"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/btn_round"
                android:textColor="#EAEAFF"
                android:text="👁"
                android:textSize="17sp"
                android:textAllCaps="false"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:contentDescription="Aperçu du cube résolu" />
        </LinearLayout>

        <!-- Ligne 2 : Annuler, Mélanger -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btnUndo"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/btn_round"
                android:textColor="#EAEAFF"
                android:text="↩ 3"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:contentDescription="Annuler" />

            <Button
                android:id="@+id/btnScramble"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/btn_round"
                android:textColor="#EAEAFF"
                android:text="🔀"
                android:textSize="16sp"
                android:textAllCaps="false"
                android:paddingLeft="0dp"
                android:paddingRight="0dp"
                android:contentDescription="Mélanger" />
        </LinearLayout>

        <!-- Ligne 3 : Réinitialiser -->
        <Button
            android:id="@+id/btnReset"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/btn_round"
            android:textColor="#EAEAFF"
            android:text="↺"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:paddingLeft="0dp"
            android:paddingRight="0dp"
            android:contentDescription="Réinitialiser" />
    </LinearLayout>

    <!-- Panneau d'aperçu (les 6 faces cibles du thème) -->
    <LinearLayout
        android:id="@+id/peekPanel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:background="@drawable/panel_bg"
        android:padding="14dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="🎯 Objectif : les 6 faces"
            android:textColor="#5EE7FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <ImageView
            android:id="@+id/peekImage"
            android:layout_width="280dp"
            android:layout_height="187dp"
            android:scaleType="fitCenter"
            android:contentDescription="Faces du thème" />
    </LinearLayout>

    <!-- Animation de victoire (au-dessus de tout, cachée par défaut) -->
    <com.tiboja.cubenova.VictoryView
        android:id="@+id/victoryView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />
</FrameLayout>
