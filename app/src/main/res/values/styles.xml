<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dialogues néon (fond sombre arrondi, accents cyan) -->
    <style name="NeonDialog" parent="@android:style/Theme.Material.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_bg</item>
        <item name="android:colorAccent">#5EE7FF</item>
        <item name="android:textColorPrimary">#EAEAFF</item>
        <item name="android:textColorSecondary">#AFAFE0</item>
        <item name="android:windowTitleStyle">@style/NeonDialogTitle</item>
    </style>

    <style name="NeonDialogTitle" parent="@android:style/TextAppearance.Material.DialogWindowTitle">
        <item name="android:textColor">#5EE7FF</item>
        <item name="android:textSize">21sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Bouton du panneau de menu -->
    <style name="MenuItemButton">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:background">@drawable/btn_neon</item>
        <item name="android:textColor">#EAEAFF</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:paddingLeft">14dp</item>
        <item name="android:paddingRight">14dp</item>
    </style>
</resources>
